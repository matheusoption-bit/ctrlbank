# Database
# PostgreSQL connection string
# Produção (Neon/Supabase/Railway): obtenha a URL no painel do provedor
# Local: postgresql://postgres:password@localhost:5432/ctrlbank?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/ctrlbank?schema=public"

# Auth
# Required: minimum 32 characters. Used to HMAC-sign session cookies so that
# forged or tampered cookies are rejected in middleware without a DB round-trip.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="replace_with_at_least_32_random_characters_here"

# App
# Produção: substitua pela URL do seu deploy na Vercel (ex: https://ctrlbank.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment
NODE_ENV="development"

# ─── Fase 10: 2FA TOTP ────────────────────────────────────────────────────────
# Não requer variáveis externas — usa otplib (HMAC-SHA1).

# ─── Fase 12: IA / CtrlBot (Groq) ────────────────────────────────────────────
# Obtenha gratuitamente em https://console.groq.com → API Keys
# Se ausente, o botão do assistente não é exibido.
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxx"
# Modelo padrão: gemma2-9b-it  (grátis · ~8B params · português ok)
# Alternativas: llama-3.1-8b-instant · mixtral-8x7b-32768
GROQ_MODEL="gemma2-9b-it"

# ─── Fase 9: Cron de Recorrentes ──────────────────────────────────────────────
# Segredo para autenticar o cron job do Vercel (Authorization: Bearer <secret>)
# Adicione também em Vercel → Settings → Environment Variables
CRON_SECRET="replace_with_a_random_secret_string_here"

# ─── Variáveis obrigatórias na Vercel (Settings → Environment Variables) ────
# DATABASE_URL        → URL do banco remoto (Neon, Supabase, Railway, etc.)
# SESSION_SECRET      → string aleatória 32+ chars
# NEXT_PUBLIC_APP_URL → URL do deploy na Vercel
# CRON_SECRET         → segredo para o cron job de recorrentes

# --- OCR de Comprovantes (Google Gemini) ---
# Obtenha gratuitamente em https://aistudio.google.com/app/apikey
# Usado para extrair dados de comprovantes, notas fiscais e boletos
GEMINI_API_KEY="sua_chave_aqui"
