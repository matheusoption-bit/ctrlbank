# Database
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/ctrlbank?schema=public"

# Auth
# Required: minimum 32 characters. Used to HMAC-sign session cookies so that
# forged or tampered cookies are rejected in middleware without a DB round-trip.
# Generate with: openssl rand -base64 32
SESSION_SECRET="replace_with_at_least_32_random_characters_here"

# App
# Public application URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment
NODE_ENV="development"
