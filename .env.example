# Database
# PostgreSQL connection string
# Produção (Neon/Supabase/Railway): obtenha a URL no painel do provedor
# Local: postgresql://postgres:password@localhost:5432/ctrlbank?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/ctrlbank?schema=public"

# Auth
# Required: minimum 32 characters. Used to HMAC-sign session cookies so that
# forged or tampered cookies are rejected in middleware without a DB round-trip.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="replace_with_at_least_32_random_characters_here"

# App
# Produção: substitua pela URL do seu deploy na Vercel (ex: https://ctrlbank.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Environment
NODE_ENV="development"

# ─── Variáveis obrigatórias na Vercel (Settings → Environment Variables) ────
# DATABASE_URL  → URL do banco remoto (Neon, Supabase, Railway, etc.)
# SESSION_SECRET → string aleatória 32+ chars (use o comando acima para gerar)
# NEXT_PUBLIC_APP_URL → URL do deploy na Vercel
